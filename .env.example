# ── Server Secrets (managed via Doppler in production) ──

# Required: 32+ character secret for encryption and token signing
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Required: The public base URL of your API server
BETTER_AUTH_URL=https://api.autter.dev

# Required: PostgreSQL connection string (e.g., Neon serverless)
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/autter

# Optional: URL for drizzle-kit migrate/studio only (TCP via `pg`). Use for local Postgres while DATABASE_URL stays Neon.
# DRIZZLE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/autter

# ── OAuth Providers (optional) ──

# GitHub OAuth — create an app at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (for OTP delivery) ──

# Resend — https://resend.com (falls back to console.log if unset)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Autter Updates <update@hello.autter.dev>
RESEND_REPLY_TO_EMAIL=Autter Team <hi@autter.dev>

# ── Device Authorization ──

# Comma-separated list of valid OAuth client IDs
VALID_CLIENT_IDS=autter-cli

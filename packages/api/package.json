{
  "name": "@autter/api",
  "version": "0.1.0",
  "private": true,
  "description": "Serverless API for autter-tracker — sync, teams, and device auth",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.44.0",
    "@neondatabase/serverless": "^1.0.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250401.0",
    "drizzle-kit": "^0.31.0",
    "pg": "^8.14.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
